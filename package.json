{
  "name": "thewhitestonefoundation-v3",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "scripts": {
    "clean": "shx rm -rf _site",
    "dev": "eleventy --serve --port=8080",
    "sequoia:stage": "node scripts/build-sequoia-content.mjs",
    "sequoia:publication": "node scripts/publish-standard-publication.mjs",
    "sequoia:publish": "npm run sequoia:stage && npm run sequoia:publication && npx -y sequoia-cli publish",
    "sequoia:publish:dry": "npm run sequoia:stage && npx -y sequoia-cli publish --dry-run",
    "sequoia:sync": "npm run sequoia:stage && npx -y sequoia-cli sync --update-frontmatter",
    "build:site": "cross-env ELEVENTY_ENV=production eleventy",
    "build:search": "pagefind --site _site --output-subdir pagefind",
    "build:assets": "esbuild _site/assets/css/index.css --minify --allow-overwrite --outfile=_site/assets/css/index.css && esbuild _site/assets/js/index.js --minify --allow-overwrite --outfile=_site/assets/js/index.js",
    "build": "npm run clean && npm run sequoia:stage && npm run build:site && npm run build:assets && npm run build:search",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "cross-env": "^10.1.0",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0",
    "pagefind": "1.5.2",
    "shx": "^0.4.0"
  },
  "engines": {
    "node": ">=24"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true
  }
}
