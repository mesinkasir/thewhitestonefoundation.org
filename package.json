{
  "name": "thewhitestonefoundation-11ty",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "sequoia:stage": "node scripts/build-sequoia-content.mjs",
    "build": "npm run sequoia:stage && rm -rf _site && npx @11ty/eleventy && node scripts/build-pagefind-import.mjs && node scripts/run-pagefind.mjs && node scripts/build-metasearch-index.mjs && node scripts/build-semantic-vectors.mjs",
    "refresh:metasearch": "node scripts/update-allsites-canonical.mjs"
  },
  "dependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@huggingface/transformers": "3.8.1",
    "eleventy-plugin-toc": "^1.1.5",
    "luxon": "^3.5.0",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-table-of-contents": "^0.8.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.4.0",
    "pagefind": "^1.4.0",
    "sentence-splitter": "5.0.0"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.14.0"
  },
  "packageManager": "npm@11.14.0",
  "overrides": {
    "undici": "~7.28.0"
  }
}
