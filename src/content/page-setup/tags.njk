---
layout: base.njk
title: "Tags"
description: "Browse Whitestone articles by topic."
permalink: /tags/
---
{% import "partials/breadcrumb.njk" as bc %}
<section class="page-shell">
  {{ bc.render(page, title, metadata, none) }}
  <header class="page-header">
    <p class="eyebrow">Browse</p>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
  </header>

  <div class="tag-cloud">
    {% for tag in collections.postTags %}
      <a class="tag-pill" href="/tags/{{ tag.slug }}/">
        {{ tag.name | titleCaseTerm }}
        <span>{{ tag.count }}</span>
      </a>
    {% else %}
      <p>No tags yet.</p>
    {% endfor %}
  </div>
</section>
