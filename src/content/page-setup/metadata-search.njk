---
layout: base.njk
title: "Search All Whitestone Sites"
description: "Search across The Whitestone Foundation, JCRT, The New Polis, The New Polis Journal, and Esthesis in one place."
permalink: /metadata/search/
---
{% import "partials/breadcrumb.njk" as bc %}
<section class="page-shell search">
  {{ bc.render(page, title, metadata, none) }}
  <header class="page-header">
    <p class="eyebrow">Metasearch</p>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
  </header>

  <div id="allsites-search">
    <noscript><p>This search requires JavaScript. You can search each site directly: <a href="https://jcrt.org/search/">JCRT</a>, <a href="https://thenewpolis.com/search/">The New Polis</a>, <a href="https://journal.thenewpolis.com/search/">The New Polis Journal</a>, <a href="https://esthesis.org/search/">Esthesis</a>.</p></noscript>
  </div>
</section>

<link rel="stylesheet" href="/pagefind/pagefind-component-ui.css">
<script type="module">
  await import("/pagefind/pagefind-component-ui.js");
  const { configureInstance } = window.PagefindComponents;

  // A single unreachable index poisons the whole search instance, so only
  // merge remote bundles that respond (a site outage then degrades to
  // fewer sources instead of breaking search entirely).
  const remotes = [
    { bundlePath: "https://jcrt.org/pagefind/", mergeFilter: { Site: "JCRT" } },
    { bundlePath: "https://thenewpolis.com/pagefind/", mergeFilter: { Site: "The New Polis" } },
    { bundlePath: "https://journal.thenewpolis.com/pagefind/", mergeFilter: { Site: "The New Polis Journal" } },
    { bundlePath: "https://esthesis.org/pagefind/", mergeFilter: { Site: "Esthesis" } }
  ];
  const probes = await Promise.allSettled(
    remotes.map((r) => fetch(`${r.bundlePath}pagefind-entry.json`, { method: "HEAD", mode: "cors" }))
  );
  const reachable = remotes.filter((r, i) => probes[i].status === "fulfilled" && probes[i].value.ok);
  const unreachable = remotes.filter((r) => !reachable.includes(r));
  if (unreachable.length) console.warn("Metasearch: skipping unreachable indexes:", unreachable.map((r) => r.bundlePath));

  // configureInstance must run before any "allsites" components connect,
  // so the components are injected only after configuration.
  configureInstance("allsites", {
    bundlePath: "/pagefind/",
    mergeFilter: { Site: "Whitestone Foundation" },
    mergeIndex: reachable
  });
  document.getElementById("allsites-search").innerHTML = `
    <pagefind-input instance="allsites" placeholder="Search all Whitestone sites"></pagefind-input>
    <pagefind-filter-dropdown instance="allsites" filter="Site"></pagefind-filter-dropdown>
    <pagefind-summary instance="allsites"></pagefind-summary>
    <pagefind-results instance="allsites"></pagefind-results>
  `;
</script>
