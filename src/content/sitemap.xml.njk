---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for item in collections.all %}
{% if item.url and not item.data.noindex and item.url != "/sitemap.xml" %}
  <url>
    <loc>{{ item.url | absUrl(metadata.url) }}</loc>
    {% if item.date %}<lastmod>{{ item.date | htmlDateString }}</lastmod>{% endif %}
  </url>
{% endif %}
{% endfor %}
  <url>
    <loc>{{ "/llms.txt" | absUrl(metadata.url) }}</loc>
  </url>
</urlset>
