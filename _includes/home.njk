--- 
layout: base.njk
--- 
<section class="hero h-entry">
<div class="row align-items-end">
<div class="col-lg-8">
<h1>{{title}}</h1>
</div>
<div class="col-lg-4">
<p>{{description}}</p>
</div>
</div>
</section>

<section class="programs-section py-4">
  <div class="row g-3">
    {% for program in metadata.publication.programs %}
    <div class="col-6 col-md-3">
      <div class="program-card p-3 text-center border rounded h-100">
        <h3 class="h5">{{ program.title }}</h3>
        <a href="{{ program.link_url }}" class="btn btn-dark rounded-0 btn-sm mt-2">
          {{ program.link_title }}
        </a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<div class="col-md-12 p-3 article-content h-entry">
{{content|safe}}
</div>
{% include "partials/post_list.njk" %}
    
