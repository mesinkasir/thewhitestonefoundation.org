{% set siteUrl = metadata.url | baseUrl %}
{% set canonicalUrl = page.url | absUrl(siteUrl) %}
{% set homeUrl = '/' | absUrl(siteUrl) %}
{% set graph = metadata.knowledge_graph %}
{% set pageImage = (image or metadata.image) | absUrl(siteUrl) %}
{% set isPost = page and page.inputPath and ("/content/posts/" in page.inputPath) %}
{% set pageType = "BlogPosting" if isPost else "WebPage" %}
{% set published = (date or page.date) | isoDate %}
{% set modified = (updated or date or page.date) | isoDate %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["{{ graph.primary_type or 'EducationalOrganization' }}", "Organization"],
      "@id": {{ graph.organization_id | dump | safe }},
      "name": "The Whitestone Foundation",
      "alternateName": "Whitestone Publications",
      "legalName": "The Whitestone Foundation",
      "url": "https://thewhitestonefoundation.org/",
      "logo": "https://thewhitestonefoundation.org/images/whitestone-logo.png",
      "image": "https://thewhitestonefoundation.org/images/whitestone-logo.png",
      "description": "The Whitestone Foundation dba Whitestone Publications advances public-interest scholarship through open-access publications, programs, and global academic collaboration.",
      "sameAs": {{ graph.same_as | dump | safe }},
      "address": {
        "@type": "PostalAddress",
        "postOfficeBoxNumber": "PO Box 396",
        "addressLocality": "Colbert",
        "addressRegion": "OK",
        "postalCode": "74733",
        "addressCountry": "US"
      },
      "publishes": { "@id": {{ graph.publications_id | dump | safe }} },
      "member": [
        { "@type": "Person", "name": "Carl Raschke", "url": "https://carlraschke.com/" },
        { "@type": "Person", "name": "Victor Taylor", "url": "https://www.linkedin.com/in/victor-e-taylor-4911342b/" },
        { "@type": "Person", "name": "Adam DJ Brett", "url": "https://adamdjbrett.com" }
      ]
    },
    {
      "@type": "ItemList",
      "@id": {{ graph.publications_id | dump | safe }},
      "name": "Whitestone Publications",
      "itemListElement": [
        { "@type": "CreativeWork", "position": 1, "name": "The Journal for Cultural and Religious Theory", "url": "https://jcrt.org/" },
        { "@type": "Periodical", "position": 2, "name": "The New Polis Journal", "url": "https://journal.thenewpolis.com/" },
        { "@type": "Blog", "position": 3, "name": "The New Polis", "url": "https://thenewpolis.com/" },
        { "@type": "Blog", "position": 4, "name": "ESTHESIS", "url": "https://esthesis.org/" }
      ]
    },
    {
      "@type": "WebSite",
      "@id": {{ graph.website_id | dump | safe }},
      "name": {{ metadata.title | dump | safe }},
      "url": {{ homeUrl | dump | safe }},
      "publisher": { "@id": {{ graph.publisher_id | dump | safe }} },
      "inLanguage": {{ (metadata.language or "en") | dump | safe }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ ("/search/?q={search_term_string}" | absUrl(siteUrl)) | dump | safe }},
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": {{ pageType | dump | safe }},
      "@id": {{ (canonicalUrl ~ "#webpage") | dump | safe }},
      "url": {{ canonicalUrl | dump | safe }},
      "name": {{ (title or metadata.title) | dump | safe }},
      "headline": {{ (title or metadata.title) | dump | safe }},
      "description": {{ (description or excerpt or metadata.description or "") | dump | safe }},
      "image": {{ pageImage | dump | safe }},
      "datePublished": {{ published | dump | safe }},
      "dateModified": {{ modified | dump | safe }},
      "inLanguage": {{ (metadata.language or "en") | dump | safe }},
      "isPartOf": { "@id": {{ graph.website_id | dump | safe }} },
      "publisher": { "@id": {{ graph.publisher_id | dump | safe }} },
      "author": {
        "@type": "Person",
        "name": {{ (author or metadata.author.name or "Whitestone Publications") | dump | safe }}
      },
      "mainEntityOfPage": { "@id": {{ canonicalUrl | dump | safe }} }
    }{% if page.url and page.url != "/" %},
    {
      "@type": "BreadcrumbList",
      "@id": {{ (canonicalUrl ~ "#breadcrumb") | dump | safe }},
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ homeUrl | dump | safe }} },
        { "@type": "ListItem", "position": 2, "name": {{ (title or metadata.title) | dump | safe }}, "item": {{ canonicalUrl | dump | safe }} }
      ]
    }{% endif %}
  ]
}
</script>
